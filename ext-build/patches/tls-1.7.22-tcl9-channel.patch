+
+/*
+ * Tcl 9 requires channel drivers to be TCL_CHANNEL_VERSION_5 with a
+ * close2Proc (closeProc must be NULL). Wrap the existing full-close path:
+ * flags==0 means close the whole channel.
+ */
+static int TlsClose2Proc(ClientData instanceData, Tcl_Interp *interp, int flags) {
+	if (flags != 0) {
+		return(EINVAL);
+	}
+	return(TlsCloseProc(instanceData, interp));
