+
+/* Debug/test helper: expose the device<->X coordinate mapping. */
+void
+SdlTkTranslatePointerPub(int rev, int *x, int *y)
+{
+    TranslatePointer(rev, x, y);
+}
+
+/*
+ * Capture (implicit pointer grab) helpers for the Tk 9.1 platform hooks.
+ * Tk 9.1's generic tkPointer.c calls TkpSetCapture(NULL) to *release* the
+ * capture; the SDL backend's native entry point is TkpSetCaptureEx(), which
+ * needs a Display.  Only one display exists here, so supply it.
  */
+int SdlTkDbgRelCount = 0, SdlTkDbgSetCount = 0;
+
+void
+SdlTkReleaseCapture(void)
+{
+    SdlTkDbgRelCount++;
+    if (SdlTkX.capture_window != NULL) {
+	/*
+	 * Release against the *capturing window's* display: sdl2tk hands out
+	 * one Display per interpreter (console vs. main), and TkpSetCaptureEx
+	 * refuses (GrabFrozen) when the display doesn't match the holder's.
+	 */
+	TkpSetCaptureEx(SdlTkX.capture_window->display, NULL);
+    }
+}
+
+Tk_Window
+SdlTkGetCapture(void)
+{
+    return (Tk_Window) SdlTkX.capture_window;
+}
+
+/* Debug/test helper: report pointer-grab related state. */
+void
+SdlTkDebugGrabState(char *buf, int len)
+{
+    extern int SdlTkDbgRelCount, SdlTkDbgSetCount;
+
+    snprintf(buf, len,
+	     "winflags=0x%x resizable=%d rel=%d set=%d sdlfocus=%d focus_nov=%p capture=%p keyboard=%p "
+	     "mouse_win=%p focus=%p",
+	     (unsigned) SDL_GetWindowFlags(SdlTkX.sdlscreen),
+	     (SDL_GetWindowFlags(SdlTkX.sdlscreen) & SDL_WINDOW_RESIZABLE) != 0,
+	     SdlTkDbgRelCount, SdlTkDbgSetCount, SdlTkX.sdlfocus,
+	     (void *) SdlTkX.focus_window_not_override,
+	     (void *) SdlTkX.capture_window, (void *) SdlTkX.keyboard_window,
+	     (void *) SdlTkX.mouse_window, (void *) SdlTkX.focus_window);
+}
